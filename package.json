{
  "name": "plugdash",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r --no-bail typecheck",
    "smoke": "node --import tsx scripts/smoke.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint --ignore-pattern '*.astro' .",
    "format": "oxfmt .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "changeset publish"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@rolldown/binding-darwin-arm64",
      "@rolldown/binding-darwin-universal",
      "esbuild",
      "better-sqlite3",
      "sharp"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "oxlint": "^0.13.0",
    "tsdown": "^0.21.7",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
