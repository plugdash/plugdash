---
interface Props {
	post: Record<string, unknown>;
	showUrl?: boolean;
	variant?: "circle" | "pill" | "ghost" | "inline";
	size?: "sm" | "md" | "lg";
	theme?: "auto" | "dark" | "light";
	class?: string;
}
const {
	post,
	showUrl = false,
	variant = "circle",
	size = "md",
	theme = "auto",
	class: className = "",
} = Astro.props;
const data = post?.data as Record<string, unknown> | undefined;
const metadata = data?.metadata as Record<string, unknown> | undefined;
const shortlink = metadata?.shortlink as
	| { url?: string; code?: string; fullUrl?: string }
	| undefined;
const url = shortlink?.fullUrl ?? shortlink?.url;
---

{
	url && (
		<button
			class={`plugdash-copy plugdash-copy--${variant} plugdash-copy--${size} plugdash-theme--${theme} ${className}`}
			data-copy={url}
			data-theme={theme}
			data-label-idle="Copy short link"
			data-label-copied="Copied!"
			aria-label="Copy short link"
			title="Copy short link"
			type="button"
		>
			{showUrl && <span class="plugdash-copy-url">{url}</span>}
			{/* link icon */}
			<svg
				class="plugdash-copy-icon"
				width="16"
				height="16"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				aria-hidden="true"
			>
				<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
				<path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
			</svg>
			{/* check icon - shown on copy */}
			<svg
				class="plugdash-copy-check"
				width="16"
				height="16"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2.5"
				aria-hidden="true"
			>
				<polyline points="20 6 9 17 4 12" />
			</svg>
		</button>
	)
}

<script>
	document.querySelectorAll(".plugdash-copy").forEach((btn) => {
		const labelIdle = btn.getAttribute("data-label-idle") || "Copy short link";
		const labelCopied = btn.getAttribute("data-label-copied") || "Copied!";
		const setLabel = (copied) => {
			const label = copied ? labelCopied : labelIdle;
			btn.setAttribute("aria-label", label);
			btn.setAttribute("title", label);
		};

		btn.addEventListener("click", async () => {
			const url = btn.getAttribute("data-copy");
			if (!url) return;
			await navigator.clipboard.writeText(url);
			btn.setAttribute("data-copied", "true");
			setLabel(true);
			const duration =
				parseInt(
					getComputedStyle(btn)
						.getPropertyValue("--plugdash-copy-success-duration")
						.replace("ms", ""),
				) || 2000;
			setTimeout(() => {
				btn.removeAttribute("data-copied");
				setLabel(false);
			}, duration);
		});
	});
</script>

<style>
	.plugdash-copy {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.3rem;
		background: none;
		border: none;
		cursor: pointer;
		color: inherit;
		font-family: var(--plugdash-font-ui, "Lexend", system-ui, sans-serif);
		transition: background var(--plugdash-engage-transition, 150ms ease);
	}

	/* circle variant - default, matches engagement bar */
	.plugdash-copy--circle {
		width: var(--plugdash-engage-size, 2rem);
		height: var(--plugdash-engage-size, 2rem);
		border-radius: var(--plugdash-engage-radius, 9999px);
		border: 1px solid
			var(
				--plugdash-engage-border,
				rgb(from currentColor r g b / 0.15)
			);
		background: var(
			--plugdash-engage-bg,
			rgb(from currentColor r g b / 0.04)
		);
	}
	.plugdash-copy--circle:hover {
		background: var(
			--plugdash-engage-bg-hover,
			rgb(from currentColor r g b / 0.08)
		);
	}

	/* pill variant */
	.plugdash-copy--pill {
		padding: 0.25rem 0.75rem;
		border-radius: var(--plugdash-radius-full, 9999px);
		border: 1px solid
			var(
				--plugdash-engage-border,
				rgb(from currentColor r g b / 0.15)
			);
		background: var(
			--plugdash-engage-bg,
			rgb(from currentColor r g b / 0.04)
		);
		font-size: var(--plugdash-size-sm, 0.875rem);
	}
	.plugdash-copy--pill:hover {
		background: var(
			--plugdash-engage-bg-hover,
			rgb(from currentColor r g b / 0.08)
		);
	}

	/* ghost variant */
	.plugdash-copy--ghost {
		padding: 0.25rem;
		border: none;
		background: none;
		opacity: 0.7;
	}
	.plugdash-copy--ghost:hover {
		opacity: 1;
	}

	/* inline variant - minimal, flows with text */
	.plugdash-copy--inline {
		padding: 0.25rem;
		border: none;
		background: none;
		opacity: 0.7;
	}
	.plugdash-copy--inline:hover {
		opacity: 1;
	}

	/* sizes */
	.plugdash-copy--sm {
		width: 1.5rem;
		height: 1.5rem;
	}
	.plugdash-copy--sm svg {
		width: 12px;
		height: 12px;
	}
	.plugdash-copy--md {
		width: var(--plugdash-engage-size, 2rem);
		height: var(--plugdash-engage-size, 2rem);
	}
	.plugdash-copy--lg {
		width: 2.5rem;
		height: 2.5rem;
	}
	.plugdash-copy--lg svg {
		width: 20px;
		height: 20px;
	}

	/* pill/ghost/inline size overrides - don't constrain width */
	.plugdash-copy--pill.plugdash-copy--sm,
	.plugdash-copy--pill.plugdash-copy--md,
	.plugdash-copy--pill.plugdash-copy--lg,
	.plugdash-copy--ghost.plugdash-copy--sm,
	.plugdash-copy--ghost.plugdash-copy--md,
	.plugdash-copy--ghost.plugdash-copy--lg,
	.plugdash-copy--inline.plugdash-copy--sm,
	.plugdash-copy--inline.plugdash-copy--md,
	.plugdash-copy--inline.plugdash-copy--lg {
		width: auto;
		height: auto;
	}

	/* check icon hidden by default, shown on copy */
	.plugdash-copy-check {
		display: none;
	}
	.plugdash-copy[data-copied="true"] .plugdash-copy-icon {
		display: none;
	}
	.plugdash-copy[data-copied="true"] .plugdash-copy-check {
		display: block;
		color: var(--plugdash-copy-success-color, #22c55e);
	}

	/* URL text */
	.plugdash-copy-url {
		font-size: var(--plugdash-size-xs, 0.75rem);
		color: var(--plugdash-muted, rgb(from currentColor r g b / 0.55));
		font-family: var(
			--plugdash-font-mono,
			"IBM Plex Mono",
			monospace
		);
	}
</style>
