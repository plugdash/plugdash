{
	"name": "@plugdash/shortlink",
	"version": "0.2.1",
	"description": "Short URLs for EmDash posts - shareable links created on publish",
	"type": "module",
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"types": "./dist/index.d.mts"
		},
		"./sandbox": {
			"import": "./dist/sandbox-entry.mjs"
		},
		"./redirect-logic": {
			"import": "./dist/redirect-logic.mjs",
			"types": "./dist/redirect-logic.d.mts"
		},
		"./CopyLink.astro": "./src/CopyLink.astro",
		"./RedirectPage.astro": "./src/RedirectPage.astro"
	},
	"files": [
		"dist",
		"src/*.astro"
	],
	"scripts": {
		"build": "tsdown src/index.ts src/sandbox-entry.ts src/redirect-logic.ts --dts.eager",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"emdash",
		"emdash-plugin",
		"shortlink",
		"pretty-links"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/plugdash/plugdash.git",
		"directory": "packages/shortlink"
	},
	"peerDependencies": {
		"emdash": "^0.1.0"
	},
	"devDependencies": {
		"@plugdash/testing": "workspace:*",
		"@plugdash/types": "workspace:*",
		"vitest": "^2.0.0"
	}
}
