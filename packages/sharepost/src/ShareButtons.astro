---
interface Props {
	post: Record<string, unknown>
	platforms?: Array<"twitter" | "linkedin" | "whatsapp" | "bluesky" | "email">
	variant?: "circle" | "pill" | "ghost" | "filled"
	size?: "sm" | "md" | "lg"
	theme?: "auto" | "dark" | "light"
	attribution?: boolean
	class?: string
}
const {
	post,
	platforms = ["twitter", "linkedin", "bluesky"],
	variant = "circle",
	size = "md",
	theme = "auto",
	attribution = false,
	class: className = "",
} = Astro.props
const data = post?.data as Record<string, unknown> | undefined
const metadata = data?.metadata as Record<string, unknown> | undefined
const shareUrls = metadata?.shareUrls as Record<string, string> | undefined

// Human-friendly display names for each platform.
const labels: Record<string, string> = {
	twitter: "X",
	linkedin: "LinkedIn",
	whatsapp: "WhatsApp",
	bluesky: "Bluesky",
	email: "Email",
}

// SVG icons - inline for zero requests
const icons: Record<string, string> = {
	twitter: `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.259 5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
	linkedin: `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
	whatsapp: `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>`,
	bluesky: `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.204-.659-.299-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8z"/></svg>`,
	email: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
}
---
{shareUrls && (
	<div
		class={`plugdash-share plugdash-share--${variant} plugdash-share--${size} plugdash-theme--${theme} ${className}`}
		data-theme={theme}
	>
		{platforms.map((p) => shareUrls[p] ? (
			<a
				href={shareUrls[p]}
				target="_blank"
				rel="noopener noreferrer"
				class={`plugdash-share-btn plugdash-share-btn--${p}`}
				aria-label={`Share on ${labels[p] ?? p}`}
				title={`Share on ${labels[p] ?? p}`}
				set:html={variant === "ghost"
					? (labels[p] ?? p)
					: variant === "pill"
						? `${icons[p]}<span>${labels[p] ?? p}</span>`
						: icons[p]}
			/>
		) : null)}
		{attribution && (
			<a
				href="https://plugdash.dev"
				class="plugdash-attribution"
				target="_blank"
				rel="noopener noreferrer"
				aria-label="Built with PlugDash"
			>
				<svg class="plugdash-attribution-logo" viewBox="0 0 256 256" fill="none" xmlns="http://www.w3.org/2000/svg">
					<path d="M56,64v96a32,32,0,0,0,32,32h80a32,32,0,0,0,32-32V64Z" fill="currentColor" opacity="0.2"/>
					<line x1="168" y1="16" x2="168" y2="64" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/>
					<path d="M88,16V64" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/>
					<path d="M128,192v48" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/>
					<path d="M32,64H224" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/>
					<path d="M56,64v96a32,32,0,0,0,32,32h80a32,32,0,0,0,32-32V64" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/>
					<polyline points="132 160 144 128 112 128 124 96" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/>
				</svg>
				<span class="plugdash-attribution-text">plugdash</span>
			</a>
		)}
	</div>
)}
<style>
	.plugdash-share {
		display: flex;
		align-items: center;
		gap: var(--plugdash-engage-gap, 0.375rem);
		font-family: var(--plugdash-font-ui, "Lexend", system-ui, sans-serif);
	}
	.plugdash-share-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.3rem;
		color: inherit;
		text-decoration: none;
		transition: background var(--plugdash-engage-transition, 150ms ease),
					opacity var(--plugdash-engage-transition, 150ms ease),
					color var(--plugdash-engage-transition, 150ms ease),
					border-color var(--plugdash-engage-transition, 150ms ease);
	}

	/* circle variant - default */
	.plugdash-share--circle .plugdash-share-btn {
		width: var(--plugdash-engage-size, 2rem);
		height: var(--plugdash-engage-size, 2rem);
		border-radius: var(--plugdash-engage-radius, 9999px);
		border: 1px solid var(--plugdash-engage-border, rgb(from currentColor r g b / 0.15));
		background: var(--plugdash-engage-bg, rgb(from currentColor r g b / 0.04));
	}
	.plugdash-share--circle .plugdash-share-btn:hover {
		background: var(--plugdash-engage-bg-hover, rgb(from currentColor r g b / 0.08));
	}

	/* pill variant */
	.plugdash-share--pill .plugdash-share-btn {
		padding: 0.3rem 0.75rem;
		border-radius: 9999px;
		border: 1px solid var(--plugdash-engage-border, rgb(from currentColor r g b / 0.15));
		font-size: var(--plugdash-size-sm, 0.875rem);
		background: var(--plugdash-engage-bg, rgb(from currentColor r g b / 0.04));
	}
	.plugdash-share--pill .plugdash-share-btn:hover {
		background: var(--plugdash-engage-bg-hover, rgb(from currentColor r g b / 0.08));
	}

	/* ghost variant */
	.plugdash-share--ghost .plugdash-share-btn {
		font-size: var(--plugdash-size-sm, 0.875rem);
		opacity: 0.6;
		text-transform: capitalize;
	}
	.plugdash-share--ghost .plugdash-share-btn:hover { opacity: 1; }

	/* filled variant */
	.plugdash-share--filled .plugdash-share-btn {
		width: var(--plugdash-engage-size, 2rem);
		height: var(--plugdash-engage-size, 2rem);
		border-radius: var(--plugdash-engage-radius, 9999px);
		background: var(--plugdash-accent, #6366f1);
		color: var(--plugdash-accent-fg, #fff);
	}
	.plugdash-share--filled .plugdash-share-btn:hover { opacity: 0.85; }

	/* sizes */
	.plugdash-share--sm { --plugdash-engage-size: var(--plugdash-engage-size-sm, 1.5rem); }
	.plugdash-share--lg { --plugdash-engage-size: var(--plugdash-engage-size-lg, 2.5rem); }

	/* ---- per-platform brand colours on hover ---- */
	/* Each platform has a CSS custom property. Users can override the
	   defaults with their own brand guideline values. */
	.plugdash-share-btn--twitter   { --plugdash-share-platform: var(--plugdash-share-twitter-color, #1d9bf0); }
	.plugdash-share-btn--linkedin  { --plugdash-share-platform: var(--plugdash-share-linkedin-color, #0a66c2); }
	.plugdash-share-btn--bluesky   { --plugdash-share-platform: var(--plugdash-share-bluesky-color, #0085ff); }
	.plugdash-share-btn--whatsapp  { --plugdash-share-platform: var(--plugdash-share-whatsapp-color, #25d366); }
	.plugdash-share-btn--email     { --plugdash-share-platform: var(--plugdash-share-email-color, var(--plugdash-accent, #6366f1)); }

	/* circle/pill: colour icon + border, keep subtle background lift */
	.plugdash-share--circle .plugdash-share-btn:hover,
	.plugdash-share--pill .plugdash-share-btn:hover {
		color: var(--plugdash-share-platform);
		border-color: var(--plugdash-share-platform);
	}

	/* ghost: colour the text/icon, no border to tint */
	.plugdash-share--ghost .plugdash-share-btn:hover {
		color: var(--plugdash-share-platform);
	}

	/* filled: swap the accent background for the platform colour */
	.plugdash-share--filled .plugdash-share-btn:hover {
		background: var(--plugdash-share-platform);
		opacity: 1;
	}

	/* attribution */
	.plugdash-attribution {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		margin-left: auto;
		text-decoration: none;
		opacity: 0.45;
		transition: opacity 0.15s;
	}
	.plugdash-attribution:hover {
		opacity: 1;
	}
	.plugdash-attribution-logo {
		width: 13px;
		height: 13px;
		color: var(--plugdash-muted, rgb(from currentColor r g b / 0.55));
		transition: color var(--plugdash-transition, 150ms ease);
	}
	.plugdash-attribution:hover .plugdash-attribution-logo {
		color: var(--plugdash-accent, #6366f1);
	}
	.plugdash-attribution-text {
		font-size: 10px;
		letter-spacing: 0.04em;
		font-weight: 400;
		color: var(--plugdash-muted, rgb(from currentColor r g b / 0.55));
		font-family: var(--plugdash-font-ui, "Lexend", system-ui, sans-serif);
	}
</style>
