{
	"name": "@plugdash/sharepost",
	"version": "0.2.1",
	"description": "Share buttons without 200KB of JavaScript - generates sharing URLs for Twitter/X, LinkedIn, WhatsApp, Bluesky, and email on publish",
	"type": "module",
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"types": "./dist/index.d.mts"
		},
		"./sandbox": {
			"import": "./dist/sandbox-entry.mjs"
		},
		"./utils": {
			"import": "./dist/utils.mjs",
			"types": "./dist/utils.d.mts"
		},
		"./ShareButtons.astro": "./src/ShareButtons.astro"
	},
	"files": [
		"dist",
		"src/*.astro"
	],
	"scripts": {
		"build": "tsdown src/index.ts src/sandbox-entry.ts src/utils.ts --dts.eager",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"emdash",
		"emdash-plugin",
		"sharepost",
		"social-sharing",
		"share-buttons"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/plugdash/plugdash.git",
		"directory": "packages/sharepost"
	},
	"peerDependencies": {
		"emdash": "^0.1.0"
	},
	"devDependencies": {
		"@plugdash/types": "workspace:*",
		"@plugdash/testing": "workspace:*",
		"vitest": "^2.0.0"
	}
}
