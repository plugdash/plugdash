{
	"name": "@plugdash/heartpost",
	"version": "0.2.0",
	"description": "Like button for EmDash posts - readers heart your content",
	"type": "module",
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"types": "./dist/index.d.mts"
		},
		"./sandbox": {
			"import": "./dist/sandbox-entry.mjs"
		},
		"./HeartButton.astro": "./src/HeartButton.astro"
	},
	"files": [
		"dist",
		"src/*.astro"
	],
	"scripts": {
		"build": "tsdown src/index.ts src/sandbox-entry.ts --dts.eager",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"emdash",
		"emdash-plugin",
		"heartpost",
		"like-button"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/plugdash/plugdash.git",
		"directory": "packages/heartpost"
	},
	"peerDependencies": {
		"emdash": "^0.1.0"
	},
	"devDependencies": {
		"@plugdash/types": "workspace:*",
		"@plugdash/testing": "workspace:*",
		"vitest": "^2.0.0"
	}
}
