---
/**
 * @plugdash/readtime - ReadingTime.astro
 *
 * Renders estimated reading time from post metadata written by the readtime plugin.
 * Renders nothing if readingTimeMinutes is not present (plugin not installed or
 * content not yet published).
 *
 * Usage:
 *   import ReadingTime from "@plugdash/readtime/ReadingTime.astro"
 *   <ReadingTime post={post} />
 *
 * Props:
 *   post      - EmDash content item (required)
 *   label     - text after the number, default "min read"
 *   variant   - "badge" | "pill" | "inline" | "minimal", default "badge"
 *   size      - "sm" | "md" | "lg", default "md"
 *   theme     - "auto" | "dark" | "light", default "auto"
 *   showWords - also show word count, default false
 *   class     - additional CSS class
 *
 * Customisation via CSS custom properties:
 *   --plugdash-rt-color       text colour (default: --plugdash-muted)
 *   --plugdash-rt-size        font size (default: per size prop)
 *   --plugdash-rt-font        font family (default: Lexend)
 *   --plugdash-rt-bg          background (badge/pill only)
 *   --plugdash-rt-border      border colour (badge only)
 *   --plugdash-rt-radius      border radius (badge/pill)
 *   --plugdash-rt-padding     padding (badge/pill)
 */

interface Props {
	post: Record<string, unknown>
	label?: string
	variant?: "badge" | "pill" | "inline" | "minimal"
	size?: "sm" | "md" | "lg"
	theme?: "auto" | "dark" | "light"
	showWords?: boolean
	attribution?: boolean
	class?: string
}

const {
	post,
	label = "min read",
	variant = "inline",
	size = "md",
	theme = "auto",
	showWords = false,
	attribution = false,
	class: className = "",
} = Astro.props

// safely navigate post.data.metadata
const data = (post as Record<string, unknown>)?.data as Record<string, unknown> | undefined
const metadata = data?.metadata as Record<string, unknown> | undefined
const minutes = typeof metadata?.readingTimeMinutes === "number"
	? metadata.readingTimeMinutes
	: null
const wordCount = typeof metadata?.wordCount === "number"
	? metadata.wordCount
	: null
---

{minutes !== null && (
	<>
		<span
			class:list={[
				"plugdash-rt",
				`plugdash-rt--${variant}`,
				`plugdash-rt--${size}`,
				className,
			]}
			data-theme={theme}
			aria-label={`${showWords && wordCount ? `${wordCount.toLocaleString()} words, ` : ""}${minutes} ${label}`}
		>
			{variant === "inline" ? (
				<>
					{showWords && wordCount !== null && (
						<><span class="plugdash-rt-words">{wordCount.toLocaleString()} words</span><span class="plugdash-rt-sep"> &middot; </span></>
					)}
					<span class="plugdash-rt-minutes">{minutes}</span>
					<span class="plugdash-rt-label"> {label}</span>
				</>
			) : (
				<>
					<span class="plugdash-rt-minutes">{minutes}</span>
					<span class="plugdash-rt-label">&thinsp;{label}</span>
					{showWords && wordCount !== null && (
						<span class="plugdash-rt-words"> &middot; {wordCount.toLocaleString()} words</span>
					)}
				</>
			)}
		</span>
		{attribution && (
			<a
				href="https://plugdash.dev"
				class="plugdash-attribution"
				target="_blank"
				rel="noopener noreferrer"
				aria-label="Built with PlugDash"
			>
				<svg class="plugdash-attribution-logo" viewBox="0 0 256 256" fill="none" xmlns="http://www.w3.org/2000/svg">
					<path d="M56,64v96a32,32,0,0,0,32,32h80a32,32,0,0,0,32-32V64Z" fill="currentColor" opacity="0.2"/>
					<line x1="168" y1="16" x2="168" y2="64" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/>
					<path d="M88,16V64" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/>
					<path d="M128,192v48" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/>
					<path d="M32,64H224" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/>
					<path d="M56,64v96a32,32,0,0,0,32,32h80a32,32,0,0,0,32-32V64" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/>
					<polyline points="132 160 144 128 112 128 124 96" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/>
				</svg>
				<span class="plugdash-attribution-text">plugdash</span>
			</a>
		)}
	</>
)}

<style>
	/* ---- base ---- */
	.plugdash-rt {
		display: inline-flex;
		align-items: baseline;
		gap: 0;
		font-family: var(--plugdash-rt-font, var(--plugdash-font-ui, "Lexend", system-ui, sans-serif));
		color: var(--plugdash-rt-color, var(--plugdash-muted, rgb(from currentColor r g b / 0.55)));
		white-space: nowrap;
		line-height: 1;
	}

	/* ---- sizes ---- */
	.plugdash-rt--sm {
		font-size: var(--plugdash-rt-size, var(--plugdash-size-xs, 0.75rem));
	}
	.plugdash-rt--md {
		font-size: var(--plugdash-rt-size, var(--plugdash-size-sm, 0.875rem));
	}
	.plugdash-rt--lg {
		font-size: var(--plugdash-rt-size, var(--plugdash-size-md, 1rem));
	}

	/* ---- variants ---- */

	/* badge - subtle rounded rectangle, slight background */
	.plugdash-rt--badge {
		padding: var(--plugdash-rt-padding, 0.2em 0.55em);
		border-radius: var(--plugdash-rt-radius, var(--plugdash-radius-sm, 4px));
		background: var(--plugdash-rt-bg, rgb(from currentColor r g b / 0.06));
		border: 1px solid var(--plugdash-rt-border, rgb(from currentColor r g b / 0.1));
	}

	/* pill - fully rounded */
	.plugdash-rt--pill {
		padding: var(--plugdash-rt-padding, 0.2em 0.7em);
		border-radius: var(--plugdash-rt-radius, 9999px);
		background: var(--plugdash-rt-bg, rgb(from currentColor r g b / 0.06));
		border: 1px solid var(--plugdash-rt-border, rgb(from currentColor r g b / 0.1));
	}

	/* inline - no background, sits in text flow */
	.plugdash-rt--inline {
		background: none;
		border: none;
		padding: 0;
		color: var(--plugdash-muted, rgb(from currentColor r g b / 0.55));
		font-size: var(--plugdash-rt-size, var(--plugdash-size-sm, 0.875rem));
	}
	.plugdash-rt--inline .plugdash-rt-sep {
		opacity: 0.5;
	}

	/* minimal - no background, slightly smaller */
	.plugdash-rt--minimal {
		font-size: calc(var(--plugdash-rt-size, 0.875em) * 0.9);
		letter-spacing: 0.02em;
	}

	.plugdash-rt-words {
		color: var(--plugdash-muted, rgb(from currentColor r g b / 0.4));
	}

	/* ---- theme overrides ---- */
	[data-theme="dark"] .plugdash-rt--badge,
	[data-theme="dark"] .plugdash-rt--pill {
		--plugdash-rt-bg: rgb(255 255 255 / 0.06);
		--plugdash-rt-border: rgb(255 255 255 / 0.1);
	}
	[data-theme="light"] .plugdash-rt--badge,
	[data-theme="light"] .plugdash-rt--pill {
		--plugdash-rt-bg: rgb(0 0 0 / 0.05);
		--plugdash-rt-border: rgb(0 0 0 / 0.08);
	}

	/* ---- auto theme via prefers-color-scheme ---- */
	@media (prefers-color-scheme: dark) {
		[data-theme="auto"] .plugdash-rt--badge,
		[data-theme="auto"] .plugdash-rt--pill {
			--plugdash-rt-bg: rgb(255 255 255 / 0.06);
			--plugdash-rt-border: rgb(255 255 255 / 0.1);
		}
	}

	/* ---- attribution ---- */
	.plugdash-attribution {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		margin-left: auto;
		text-decoration: none;
		opacity: 0.45;
		transition: opacity 0.15s;
	}
	.plugdash-attribution:hover {
		opacity: 1;
	}
	.plugdash-attribution-logo {
		width: 13px;
		height: 13px;
		color: var(--plugdash-muted, rgb(from currentColor r g b / 0.55));
		transition: color var(--plugdash-transition, 150ms ease);
	}
	.plugdash-attribution:hover .plugdash-attribution-logo {
		color: var(--plugdash-accent, #6366f1);
	}
	.plugdash-attribution-text {
		font-size: 10px;
		letter-spacing: 0.04em;
		font-weight: 400;
		color: var(--plugdash-muted, rgb(from currentColor r g b / 0.55));
		font-family: var(--plugdash-font-ui, "Lexend", system-ui, sans-serif);
	}
</style>
