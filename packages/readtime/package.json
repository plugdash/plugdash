{
	"name": "@plugdash/readtime",
	"version": "0.1.0",
	"type": "module",
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"types": "./dist/index.d.mts"
		},
		"./sandbox": {
			"import": "./dist/sandbox-entry.mjs"
		},
		"./ReadingTime.astro": "./src/ReadingTime.astro"
	},
	"files": ["dist", "src/*.astro"],
	"scripts": {
		"build": "tsdown src/index.ts src/sandbox-entry.ts --dts",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"keywords": ["emdash", "emdash-plugin"],
	"license": "MIT",
	"peerDependencies": {
		"emdash": "^0.1.0"
	},
	"devDependencies": {
		"@plugdash/types": "workspace:*",
		"@plugdash/testing": "workspace:*",
		"@portabletext/types": "^2.0.0",
		"vitest": "^2.0.0"
	}
}
