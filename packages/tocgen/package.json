{
	"name": "@plugdash/tocgen",
	"version": "0.2.1",
	"description": "Auto-generated table of contents for EmDash posts",
	"type": "module",
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"types": "./dist/index.d.mts"
		},
		"./sandbox": {
			"import": "./dist/sandbox-entry.mjs"
		},
		"./utils": {
			"import": "./dist/utils.mjs",
			"types": "./dist/utils.d.mts"
		},
		"./TableOfContents.astro": "./src/TableOfContents.astro"
	},
	"files": [
		"dist",
		"src/*.astro"
	],
	"scripts": {
		"build": "tsdown src/index.ts src/sandbox-entry.ts src/utils.ts --dts.eager --external @portabletext/types",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"emdash",
		"emdash-plugin",
		"tocgen",
		"table-of-contents"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/plugdash/plugdash.git",
		"directory": "packages/tocgen"
	},
	"peerDependencies": {
		"emdash": "^0.1.0",
		"@portabletext/types": "^2.0.0"
	},
	"devDependencies": {
		"@plugdash/types": "workspace:*",
		"@plugdash/testing": "workspace:*",
		"@portabletext/types": "^2.0.0",
		"vitest": "^2.0.0"
	}
}
