{
	"name": "@plugdash/callout",
	"version": "0.1.1",
	"description": "Callout blocks for EmDash - the block type WordPress themes always hacked with shortcodes",
	"type": "module",
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"types": "./dist/index.d.mts"
		},
		"./astro": "./src/astro/index.ts",
		"./Callout.astro": "./src/Callout.astro"
	},
	"files": [
		"dist",
		"src/astro",
		"src/*.astro"
	],
	"scripts": {
		"build": "tsdown src/index.ts --dts.eager",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"emdash",
		"emdash-plugin",
		"callout",
		"admonition"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/plugdash/plugdash.git",
		"directory": "packages/callout"
	},
	"peerDependencies": {
		"emdash": "^0.1.0"
	},
	"devDependencies": {
		"@plugdash/types": "workspace:*",
		"@plugdash/testing": "workspace:*",
		"vitest": "^2.0.0"
	}
}
